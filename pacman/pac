# 动态绑定 AUR 助手 (paru 优先，yay 兜底)
install_yay() {
    if ! command -v git >/dev/null 2>&1; then
        echo -e "\033[31m${MSG[ERR_NO_GIT]}\033[0m" >&2
        exit 1
    fi
    if ! pacman -Qg base-devel >/dev/null 2>&1; then
        echo -e "\033[31m${MSG[ERR_NO_BASE_DEVEL]}\033[0m" >&2
        exit 1
    fi
    echo -e "\033[33m${MSG[INSTALLING_YAY]}\033[0m"
    local yay_build_dir
    yay_build_dir=$(mktemp -d -t pac-yay-build.XXXXXX)
    if ! git clone --depth=1 https://aur.archlinux.org/yay.git "$yay_build_dir" >&2; then
        echo -e "\033[31m${MSG[YAY_INSTALL_FAIL]}\033[0m" >&2
        rm -rf "$yay_build_dir"
        exit 1
    fi
    if ! (cd "$yay_build_dir" && makepkg -si); then
        echo -e "\033[31m${MSG[YAY_INSTALL_FAIL]}\033[0m" >&2
        rm -rf "$yay_build_dir"
        exit 1
    fi
    rm -rf "$yay_build_dir"
    AUR_HELPER="yay"
    echo -e "\033[32m${MSG[YAY_INSTALL_OK]}\033[0m"
}

AUR_HELPER=""
if command -v paru >/dev/null 2>&1; then
    AUR_HELPER="paru"
elif command -v yay >/dev/null 2>&1; then
    AUR_HELPER="yay"
else
    echo -e "\033[33m${MSG[ASK_INSTALL_YAY]}\033[0m" >&2
    read -r answer || answer="n"
    case "${answer:-Y}" in
        y|Y|yes|YES) install_yay ;;
        *) echo -e "\033[31m${MSG[ERR_HELPER]}\033[0m" >&2; exit 1 ;;
    esac
fi

