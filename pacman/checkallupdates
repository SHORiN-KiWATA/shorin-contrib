#!/bin/bash
# Description: 检查所有可用的更新
# ==============================================================================
# 脚本名称：shorin-check-arch-updates
# 功能描述：终端下使用 fzf 显示所有待更新的软件包（Pacman, AUR, Flatpak）
# 特性：
#   1. 颜色高亮：支持 Matugen 兼容的颜色高亮，精确区分软件源。
#   2. 极速启动：优先读取 Waybar 独立缓存，实现秒开。
#   3. 交互更新：按 Enter 调用 shorin sysup，并带智能上下文感知防闪退。
#   4. 异步刷新：Ctrl+R 强制刷新时，前端独立测速并展示，同时异步唤醒 Waybar 
#      后台更新状态，互不阻塞，保证极致流畅度。
# ==============================================================================

set -euo pipefail

# === 获取脚本自身的绝对路径 (供 fzf reload 使用) ===
SCRIPT_PATH=$(readlink -f "$0")

# === 解析内部参数 ===
FORCE_REFRESH=0
if [[ "${1:-}" == "--refresh" ]]; then
    FORCE_REFRESH=1
fi

# === 配置区域 ===
CACHE_DIR="$HOME/.cache/shorin-check-arch-updates"
CACHE_REPO="$CACHE_DIR/updates-repo.txt"
CACHE_AUR="$CACHE_DIR/updates-aur.txt"
CACHE_MAX_AGE=3600

# 确保缓存目录存在
mkdir -p "$CACHE_DIR"

# === 颜色定义 (Matugen 兼容) ===
export C_TERTIARY=$'\x1b[1;35m'  # 洋红 - Flatpak
export C_PRIMARY=$'\x1b[1;34m'   # 蓝色 - AUR
export C_CYAN=$'\x1b[1;36m'      # 青色 - Pacman
export C_RESET=$'\x1b[0m'        # 重置

# === 工具函数 ===
check_cmd() {
    command -v "$1" &> /dev/null
}

# === 获取 Arch Linux 更新 ===
get_arch_updates() {
    local use_cache=0

    # 如果不是独立的强制刷新，且缓存存在，则验证缓存新鲜度
    if [[ $FORCE_REFRESH == 0 ]] && [[ -f "$CACHE_REPO" ]]; then
        local current_time file_time
        current_time=$(date +%s)
        file_time=$(stat -c %Y "$CACHE_REPO")
        if (( current_time - file_time < CACHE_MAX_AGE )); then
            use_cache=1
        fi
    fi

    if (( use_cache == 1 )); then
        # 走缓存极速输出
        if [[ -s "$CACHE_REPO" ]]; then
            grep -v '^\s*$' "$CACHE_REPO" | awk -v c1="$C_CYAN" -v cr="$C_RESET" '{print c1 "[Pacman]  " cr $0}' || true
        fi
        if [[ -s "$CACHE_AUR" ]]; then
            grep -v '^\s*$' "$CACHE_AUR" | awk -v c1="$C_PRIMARY" -v cr="$C_RESET" '{print c1 "[AUR]     " cr $0}' || true
        fi
    else
        # 缓存失效或 Ctrl+R 强制刷新时的独立查询机制（绕过缓存）
        if check_cmd checkupdates; then
            checkupdates 2>/dev/null | awk -v c1="$C_CYAN" -v cr="$C_RESET" '{print c1 "[Pacman]  " cr $0}' || true
        fi
        
        local aur_helper=""
        if check_cmd paru; then
            aur_helper="paru"
        elif check_cmd yay; then
            aur_helper="yay"
        fi

        if [[ -n "$aur_helper" ]]; then
            "$aur_helper" -Qua 2>/dev/null | awk -v c1="$C_PRIMARY" -v cr="$C_RESET" '{print c1 "[AUR]     " cr $0}' || true
        fi
    fi
}

# === 获取 Flatpak 更新 ===
get_flatpak_updates() {
    if check_cmd flatpak; then
        flatpak remote-ls --updates --columns=application,version 2>/dev/null | awk -v c1="$C_TERTIARY" -v cr="$C_RESET" '{print c1 "[Flatpak] " cr $0}' || true
    fi
}

# === 主控制逻辑 ===
main() {
# ---------------------------------------------------------
    # 分支 1：Ctrl+R 触发的重载刷新进程
    # ---------------------------------------------------------
    if [[ $FORCE_REFRESH == 1 ]]; then
        # 1. 唤醒 Waybar 后台守护进程去干活
        pkill -SIGUSR1 -f "check-updates.sh" || true
        
        # 2. 停顿 0.2 秒，确保 Waybar 的 trap 已经触发并拿到了独占文件锁
        sleep 0.2
        
        # 3. 核心修复：使用 flock 阻塞等待！
        # 避免与 Waybar 争抢 Pacman 的 db.lck 锁。我们在这里排队，
        # 一旦拿到锁，说明 Waybar 已经查完并写好了最新缓存。
        (
            flock -x -w 120 9
        ) 9>"/tmp/waybar-updates.lock" || true
        
        # 4. Waybar 已经准备好了最新鲜的数据，把刷新标志归零，直接走缓存极速读取！
        FORCE_REFRESH=0
        get_arch_updates
        get_flatpak_updates
        exit 0
    fi

    # ---------------------------------------------------------
    # 分支 2：主进程逻辑，启动 fzf UI 界面
    # ---------------------------------------------------------
    if ! check_cmd fzf; then
        echo "错误: 系统未安装 fzf。请先安装。" >&2
        sleep 3
        exit 1
    fi

    if {
        get_arch_updates
        get_flatpak_updates
    } | fzf \
        --ansi \
        --prompt="📦 待更新项目 > " \
        --layout=reverse \
        --info=inline \
        --header="ESC退出 | Enter更新系统 | Ctrl+R强制刷新" \
        --bind="ctrl-r:change-prompt(⏳ 正在拉取最新数据... > )+reload('${SCRIPT_PATH}' --refresh)+change-prompt(📦 待更新项目 > )" \
        > /dev/null; then
        
        clear
        echo -e "${C_CYAN}正在启动系统更新 (shorin sysup)...${C_RESET}\n"
        
        shorin sysup --do-update
        
        echo -e "\n${C_PRIMARY}更新流程结束${C_RESET}"

        # === 智能终端暂停逻辑 ===
        local parent_cmd
        parent_cmd=$(ps -o comm= -p $PPID 2>/dev/null | sed 's/^-//' || true)
        
        if ! [[ "$parent_cmd" =~ ^(bash|zsh|fish|tcsh|tmux|screen)$ ]]; then
            echo -e "${C_TERTIARY}按任意键关闭窗口...${C_RESET}"
            read -n 1 -s
        fi
    fi
}

main
