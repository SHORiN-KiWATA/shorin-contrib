def t(key, *args):
    s = I18N[LANG].get(key, key)
    if args: return s.format(*args)
    return s

def str_width(s):
    """计算中英文字符串在终端的实际显示宽度 (东亚全角字符算2)"""
    return sum(2 if unicodedata.east_asian_width(c) in 'WF' else 1 for c in s)

def truncate_str(s, max_width):
    """根据显示宽度安全截断字符串"""
    w = 0
    res = []
    for c in s:
        cw = 2 if unicodedata.east_asian_width(c) in 'WF' else 1
        if w + cw > max_width: break
        res.append(c)
        w += cw
    return "".join(res)

def pad_str(s, width):
    """根据显示宽度填充空格对齐"""
    w = str_width(s)
    return s + " " * max(0, width - w)


# ─── API Key Storage Logic ───
CACHE_DIR = os.path.expanduser("~/.cache/searchmodels")
KEY_FILE = os.path.join(CACHE_DIR, "keys.json")
CUSTOM_FILE = os.path.join(CACHE_DIR, "custom.json")

def get_machine_salt():
    return "searchmodels_local_salt_8a2b"

def xor_crypt(text, key=None):
    if not text: return ""
    if not key: key = get_machine_salt()
    expanded_key = (key * (len(text) // len(key) + 1))[:len(text)]
    return "".join(chr(ord(c) ^ ord(k)) for c, k in zip(text, expanded_key))

def load_keys():
    if not os.path.exists(KEY_FILE): return {}
    try:
        with open(KEY_FILE, "r") as f: data = json.load(f)
        result = {}
        for k, v in data.items():
            decrypted = xor_crypt(base64.b64decode(v.encode()).decode())
            if not any(ord(c) < 32 for c in decrypted):
                result[k] = decrypted
        return result
    except Exception: return {}

def save_key(provider_name, api_key):
    os.makedirs(CACHE_DIR, exist_ok=True)
    try:
        with open(KEY_FILE, "r") as f: data = json.load(f)
    except Exception: data = {}
    data[provider_name] = base64.b64encode(xor_crypt(api_key).encode()).decode()
    with open(KEY_FILE, "w") as f: json.dump(data, f)
    try: os.chmod(KEY_FILE, 0o600)
    except Exception: pass

def load_custom_providers():
    if not os.path.exists(CUSTOM_FILE): return []
    try:
        with open(CUSTOM_FILE, "r") as f: 
            data = json.load(f)
            if isinstance(data, list): return data
    except Exception: pass
    return []

def save_custom_providers(providers):
    os.makedirs(CACHE_DIR, exist_ok=True)
    customs = [p for p in providers if p.get("is_custom")]
    with open(CUSTOM_FILE, "w") as f: json.dump(customs, f)

