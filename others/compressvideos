#!/usr/bin/env bash
# 压缩视频大小

set -u

# ==========================================
# 多语言支持 (Bilingual Support)
# ==========================================
LANG_ID="en"
if [[ "${LANG:-}" == *"zh_CN"* || "${LANGUAGE:-}" == *"zh_CN"* || "${LC_ALL:-}" == *"zh_CN"* || "${LC_MESSAGES:-}" == *"zh_CN"* ]]; then
    LANG_ID="zh"
fi

# 在 tty 终端中通常不支持 CJK 字符，回退为英文
if [[ "$(tty 2>/dev/null)" == /dev/tty[0-9]* ]] || [[ "${TERM:-}" == "linux" ]]; then
    LANG_ID="en"
fi

if [ "$LANG_ID" = "zh" ]; then
